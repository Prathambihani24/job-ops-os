{
  "name": "gtm-os-job-search",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.13.0",
  "engines": {
    "node": ">=24.16.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "check-env": "node ./scripts/check-env.mjs",
    "dev:api": "node --env-file=.env ./apps/api/src/server.js",
    "start:api": "node --env-file=.env ./apps/api/src/server.js",
    "test": "node --test ./apps/api/test/**/*.test.js",
    "test:config": "npm --workspace @gtm-os/config test"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "next": "^15.3.4",
    "postcss": "^8.5.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "tsx": "^4.19.0"
  }
}
