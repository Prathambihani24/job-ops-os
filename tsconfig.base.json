{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@gtm-os/config": ["packages/config/src/index.ts"],
      "@gtm-os/providers": ["packages/providers/src/index.ts"],
      "@gtm-os/shared-domain": ["packages/shared-domain/src/index.ts"],
      "@gtm-os/types": ["packages/types/src/index.ts"]
    }
  }
}
