# Core runtime
NODE_ENV=development
PORT=3000
APP_NAME=gtm-os-portfolio
LOG_LEVEL=info
API_BASE_URL=http://localhost:3000
WEBHOOK_SIGNING_SECRET=replace-with-a-long-random-string
APP_URL=http://localhost:3001

# Database
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me
SUPABASE_JWT_SECRET=replace-me

# n8n
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5678
N8N_ENCRYPTION_KEY=replace-with-a-32-character-key

# HubSpot
HUBSPOT_ACCESS_TOKEN=replace-me

# Slack
SLACK_BOT_TOKEN=xoxb-replace-me
SLACK_SIGNING_SECRET=replace-me
SLACK_DEFAULT_CHANNEL_ID=C0000000000

# Default AI provider: free local inference with Ollama
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b

# Optional documentation storage
NOTION_API_KEY=secret_replace_me
NOTION_DATABASE_ID=replace-me

# Optional premium AI providers
# Recommended: Groq is free (no credit card), fast, and good enough quality
# for resume tailoring. Get a key in 30 seconds at console.groq.com/keys.
# If both GROQ_API_KEY and ANTHROPIC_API_KEY are set, Groq is tried first.
GROQ_API_KEY=replace-me
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-5.1
ANTHROPIC_API_KEY=replace-me
ANTHROPIC_MODEL=claude-sonnet-5

# Optional premium data-source plugins
APOLLO_API_KEY=replace-me
CLAY_API_KEY=replace-me
LINKEDIN_SESSION_COOKIE=replace-me
GMAIL_CLIENT_ID=replace-me
GMAIL_CLIENT_SECRET=replace-me
GOOGLE_CALENDAR_CLIENT_ID=replace-me
GOOGLE_CALENDAR_CLIENT_SECRET=replace-me

# Optional observability integrations
SENTRY_DSN=https://example.ingest.sentry.io/000000
BETTER_STACK_SOURCE_TOKEN=replace-me
